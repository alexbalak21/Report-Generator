{
  "config": {
    "data_file": "C:/repport gen/table.xlsx",
    "template_file": "C:/repport gen/template.docx",
    "output_dir": "C:\\repport gen\\out"
  },
  "date": "{{date}}",
  "species": "{{species}}",
  "address": "{{address}}",
  "inspector": "{{inspector}}",
  "notes": "{{notes}}",
  "product": "{{product}}",
  "today_date": {
    "operation": "today",
    "format": "%d/%m/%Y"
  },
  "species_upper": {
    "operation": "uppercase",
    "input": "species"
  },
  "full_line": {
    "operation": "format",
    "format": "{species} inspected on {date}"
  },
  "report_number": {
    "operation": "report_number"
  },
  "file_name": {
    "operation": "format",
    "format": "{species}_{date}_{report_number}.docx"
  }
}